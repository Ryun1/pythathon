# Cardano wallet mnemonic (24 words)
CARDANO_MNEMONIC=

# Pyth Lazer authentication token
LAZER_TOKEN=

# Hex-encoded policy ID of the Cardano Pyth deployment
POLICY_ID=

# Cardano data provider: blockfrost | koios | maestro
PROVIDER=koios

# Provider credential (required for Blockfrost/Maestro, optional for Koios)
PROVIDER_TOKEN=

# Cardano network: mainnet | preprod | preview
NETWORK=preprod
